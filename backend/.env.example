PORT=5000
FRONTEND_URL=http://localhost:5173

# Use firebase/firestore for Firebase-backed data.
DATA_PROVIDER=firebase

# Firebase Admin credentials. Use one of the three styles below when DATA_PROVIDER=firebase.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Or paste the complete service account JSON.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Or paste the base64-encoded complete service account JSON.
FIREBASE_SERVICE_ACCOUNT_

# Optional when you also use Firebase Realtime Database.
FIREBASE_DATABASE_URL=
